   "cell_type":"code",
   "source":["# @title 4. Download ZIP\n","import zipfile\n","from google.colab import files\n","z = \"/content/wing_photos.zip\"\n","with zipfile.ZipFile(z, 'w') as zf:\n","    for i in results: zf.write(i, os.path.basename(i))\n","files.download(z)\n","print(\"\u2705 Done!\")"
   ],
