   "cell_type":"code",
   "source":["# @title 1. Install ComfyUI + Flux\n","import os, sys, json, time, requests, threading, random\n","from IPython.display import display, Image as IPImage\n","\n","COMFY = \"/content/ComfyUI\"\n","if not os.path.exists(COMFY):\n","    print(\"\u2699\ufe0f Installing ComfyUI...\")\n","    !git clone --depth 1 https://github.com/comfyanonymous/ComfyUI {COMFY} 2>/dev/null\n","    !cd {COMFY} && pip install -q -r requirements.txt 2>&1 | tail -1\n","\n","md = f\"{COMFY}/models/checkpoints\"\n","os.makedirs(md, exist_ok=True)\n","if not os.path.exists(f\"{md}/flux1-dev-fp8.safetensors\"):\n","    print(\"\U0001f4e5 Flux fp8 (~12GB, 3-5 min)...\")\n","    !wget -q --show-progress -O {md}/flux1-dev-fp8.safetensors https://huggingface.co/Comfy-Org/flux1-dev/resolve/main/flux1-dev-fp8.safetensors\n","\n","cd_ = f\"{COMFY}/models/clip\"\n","os.makedirs(cd_, exist_ok=True)\n","if not os.path.exists(f\"{cd_}/t5xxl_fp8.safetensors\"):\n","    print(\"\U0001f4e5 T5 encoder...\")\n","    !wget -q --show-progress -O {cd_}/t5xxl_fp8.safetensors https://huggingface.co/Comfy-Org/flux1-dev/resolve/main/t5xxl_fp8.safetensors\n","if not os.path.exists(f\"{cd_}/clip_l.safetensors\"):\n","    print(\"\U0001f4e5 CLIP-L...\")\n","    !wget -q --show-progress -O {cd_}/clip_l.safetensors https://huggingface.co/Comfy-Org/flux1-dev/resolve/main/clip_l.safetensors\n","\n","os.makedirs(f\"{COMFY}/models/vae\", exist_ok=True)\n","if not os.path.exists(f\"{COMFY}/models/vae/ae.safetensors\"):\n","    print(\"\U0001f4e5 VAE...\")\n","    !wget -q --show-progress -O {COMFY}/models/vae/ae.safetensors https://huggingface.co/black-forest-labs/FLUX.1-dev/resolve/main/ae.safetensors\n","print(\"\u2705 Ready!\")"
   ],
