   "cell_type":"code",
   "source":["# @title 2. Start Server\n","def start():\n","    !cd {COMFY} && python main.py --dont-print-server --listen 0.0.0.0 --port 8188 2>&1\n","threading.Thread(target=start, daemon=True).start()\n","for i in range(60):\n","    try:\n","        r = requests.get(\"http://127.0.0.1:8188/system_stats\", timeout=2)\n","        if r.status_code == 200: print(\"\u2705 Server running!\"); break\n","    except: pass\n","    time.sleep(2)"
   ],
